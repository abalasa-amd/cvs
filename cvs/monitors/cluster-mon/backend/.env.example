# GPU Cluster Monitor Configuration

# Application
DEBUG=false

# Nodes (comma-separated, or use nodes_file)
# NODES=192.168.1.10,192.168.1.11,192.168.1.12
NODES_FILE=config/nodes.txt

# SSH Configuration
SSH__USERNAME=root
SSH__KEY_FILE=~/.ssh/id_rsa
# SSH__PASSWORD=your_password
SSH__TIMEOUT=30

# Polling
POLLING__INTERVAL=15
POLLING__BATCH_SIZE=10
POLLING__STAGGER_DELAY=2

# Redis
REDIS__HOST=localhost
REDIS__PORT=6379
REDIS__DB=0
REDIS__TTL=900

# InfluxDB
INFLUXDB__URL=http://localhost:8086
INFLUXDB__ORG=gpu-monitor
INFLUXDB__BUCKET=gpu_cluster
# INFLUXDB__TOKEN=your_token_here

# Alerts
ALERTS__GPU_TEMP_THRESHOLD=85.0
ALERTS__GPU_UTIL_THRESHOLD=95.0
ALERTS__GPU_MEM_THRESHOLD=95.0
ALERTS__ERROR_COUNT_THRESHOLD=10
ALERTS__NIC_ERROR_THRESHOLD=100

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
