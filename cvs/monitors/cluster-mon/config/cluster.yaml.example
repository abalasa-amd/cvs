cluster:
  nodes_file: config/nodes.txt

  ssh:
    username: your_username
    key_file: ~/.ssh/id_rsa
    timeout: 30

    jump_host:
      enabled: false
      host: jumphost.example.com
      username: your_username
      key_file: ~/.ssh/id_rsa
      node_username: your_username
      node_key_file: ~/.ssh/id_rsa

  polling:
    interval: 60
    batch_size: 10
    stagger_delay: 2
    failure_threshold: 5

  alerts:
    gpu_temp_threshold: 85.0
    gpu_util_threshold: 95.0
